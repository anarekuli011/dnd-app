rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────
    // Users can read/write only their own profile.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    // ── Characters ────────────────────────────────────────────────
    // Owners have full access; other signed-in users can read
    // (needed so GM can view player stats during sessions).
    match /characters/{charId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn()
                            && resource.data.ownerId == request.auth.uid;
    }

    // ── Campaigns ─────────────────────────────────────────────────
    // GM has full control; players in the campaign can read.
    match /campaigns/{campaignId} {
      allow read: if isSignedIn()
                  && (resource.data.gmId == request.auth.uid
                      || request.auth.uid in resource.data.playerIds);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
                            && resource.data.gmId == request.auth.uid;

      // Encounters sub-collection — GM only
      match /encounters/{encId} {
        allow read, write: if isSignedIn()
                           && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.gmId == request.auth.uid;
      }

      // NPCs sub-collection — GM only
      match /npcs/{npcId} {
        allow read, write: if isSignedIn()
                           && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.gmId == request.auth.uid;
      }
    }

    // ── Sessions ──────────────────────────────────────────────────
    // Any signed-in user can read sessions (the 6-char join code
    // acts as the access-control gate — you can't join without it).
    // GM has full update/delete rights. Non-GM players can ONLY
    // update connectedPlayers (to add/remove themselves).
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();

      allow update: if isSignedIn()
                    && (
                      // GM can update anything
                      resource.data.gmId == request.auth.uid
                      // Non-GM: only connectedPlayers changed
                      || (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["connectedPlayers"])
                        && (
                          request.auth.uid in request.resource.data.connectedPlayers
                          || request.auth.uid in resource.data.connectedPlayers
                        )
                      )
                    );

      allow delete: if isSignedIn()
                    && resource.data.gmId == request.auth.uid;

      // Roll log — anyone in the session can read; Cloud Functions write
      match /rollLog/{rollId} {
        allow read: if isSignedIn();
        allow write: if false; // Only Cloud Functions should write rolls
      }

      // Active effects — GM writes, players read
      match /activeEffects/{effectId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
                     && get(/databases/$(database)/documents/sessions/$(sessionId)).data.gmId == request.auth.uid;
      }

      // Roll requests — GM creates, target player can read
      match /rollRequests/{requestId} {
        allow read: if isSignedIn()
                    && (resource.data.targetPlayerId == request.auth.uid
                        || get(/databases/$(database)/documents/sessions/$(sessionId)).data.gmId == request.auth.uid);
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/sessions/$(sessionId)).data.gmId == request.auth.uid;
        allow update: if false; // Cloud Functions handle completion
      }

      // GM notes — GM only
      match /gmNotes/{noteId} {
        allow read, write: if isSignedIn()
                           && get(/databases/$(database)/documents/sessions/$(sessionId)).data.gmId == request.auth.uid;
      }

      // Presence — heartbeat-based online tracking.
      // Each player writes their own doc (uid == docId).
      // All session members can read. Players can only write/delete
      // their own presence doc. GM can also delete any (cleanup).
      match /presence/{presenceUid} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
                               && request.auth.uid == presenceUid;
        allow delete: if isSignedIn()
                      && (request.auth.uid == presenceUid
                          || get(/databases/$(database)/documents/sessions/$(sessionId)).data.gmId == request.auth.uid);
      }
    }
  }
}
